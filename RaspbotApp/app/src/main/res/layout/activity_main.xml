<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:gravity="center_vertical"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <TextView
            android:id="@+id/tvPageTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="首页"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_default"
            android:paddingLeft="8dp"
            android:paddingTop="2dp"
            android:paddingRight="8dp"
            android:paddingBottom="2dp"
            android:text="v1.0"
            android:textColor="@color/text_tertiary"
            android:textSize="10sp" />
    </LinearLayout>

    <FrameLayout
        android:id="@+id/commonVideoCard"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_marginLeft="18dp"
        android:layout_marginRight="18dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_video_card">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/rtcVideo"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="实时画面"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/imgVideoFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#08080C"
            android:contentDescription="实时画面"
            android:scaleType="centerCrop" />

        <View
            android:id="@+id/videoToneOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#00000000" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|start"
            android:layout_marginLeft="10dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_live_tag"
            android:paddingLeft="7dp"
            android:paddingTop="2dp"
            android:paddingRight="7dp"
            android:paddingBottom="2dp"
            android:text="LIVE"
            android:textColor="@android:color/white"
            android:textSize="9sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvVideoStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_marginTop="8dp"
            android:layout_marginRight="10dp"
            android:background="@drawable/bg_fps_tag"
            android:paddingLeft="7dp"
            android:paddingTop="2dp"
            android:paddingRight="7dp"
            android:paddingBottom="2dp"
            android:text="等待视频"
            android:textColor="@color/text_secondary"
            android:textSize="10sp" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <ScrollView
            android:id="@+id/pageHome"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginRight="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="连接"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvConnection"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:text="● 在线"
                            android:textColor="@color/green"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginLeft="4dp"
                        android:layout_marginRight="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="主机"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvHostDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:maxLines="1"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="11sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/cardAlertSummary"
                        android:layout_width="0dp"
                        android:layout_height="64dp"
                        android:layout_marginLeft="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:padding="10dp">

                        <TextView
                            android:id="@+id/tvAlertLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:clickable="true"
                            android:focusable="true"
                            android:text="报警"
                            android:textColor="@color/text_tertiary"
                            android:textSize="9sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvAlertCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="3dp"
                            android:clickable="true"
                            android:focusable="true"
                            android:text="0"
                            android:textColor="@color/red"
                            android:textSize="13sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="14dp"
                    android:orientation="horizontal"
                    android:weightSum="4">

                    <include layout="@layout/item_metric_distance" />
                    <include layout="@layout/item_metric_temp" />
                    <include layout="@layout/item_metric_smoke" />
                    <include layout="@layout/item_metric_light" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layoutAlarmBanner"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_btn_danger"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="10dp"
                    android:visibility="gone">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_marginRight="8dp"
                        android:src="@drawable/ic_bell"
                        app:tint="@color/red" />

                    <TextView
                        android:id="@+id/tvAlarmText"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        android:text="报警"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAlarmCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_alert_badge"
                        android:clickable="true"
                        android:focusable="true"
                        android:paddingLeft="8dp"
                        android:paddingTop="2dp"
                        android:paddingRight="8dp"
                        android:paddingBottom="2dp"
                        android:text="0条"
                        android:textColor="@color/red"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageControl"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <TextView
                    style="@style/SectionLabel"
                    android:text="控制模式" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="14dp"
                    android:background="@drawable/bg_chip_default"
                    android:orientation="horizontal"
                    android:padding="3dp">

                    <Button
                        android:id="@+id/btnManualMode"
                        style="@style/SegmentButton"
                        android:background="@drawable/bg_chip_selected_dark"
                        android:text="手动"
                        android:textColor="@color/text_primary" />

                    <Button
                        android:id="@+id/btnAutoMode"
                        style="@style/SegmentButton"
                        android:background="@drawable/bg_chip_default"
                        android:text="自动追踪"
                        android:textColor="@color/text_secondary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginRight="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            style="@style/SectionLabel"
                            android:text="方向" />

                        <com.example.raspbotapp.ui.DirectionPadView
                            android:id="@+id/directionPad"
                            android:layout_width="match_parent"
                            android:layout_height="132dp"
                            android:layout_marginTop="7dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="速度"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvSpeedVal"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="80"
                                    android:textColor="@color/text_primary"
                                    android:textSize="15sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <SeekBar
                                android:id="@+id/seekSpeed"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="255"
                                android:progress="80"
                                android:progressTint="@color/amber"
                                android:thumbTint="@color/amber" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:orientation="horizontal">

                                <TextView
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="扬声器"
                                    android:textColor="@color/text_secondary"
                                    android:textSize="11sp" />

                                <TextView
                                    android:id="@+id/tvSpeakerVolume"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="80%"
                                    android:textColor="@color/text_primary"
                                    android:textSize="13sp"
                                    android:textStyle="bold" />
                            </LinearLayout>

                            <SeekBar
                                android:id="@+id/seekSpeakerVolume"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:max="100"
                                android:progress="80"
                                android:progressTint="@color/amber"
                                android:thumbTint="@color/amber" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_panel"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <TextView
                            style="@style/SectionLabel"
                            android:text="云台微调" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="水平"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <SeekBar
                            android:id="@+id/seekServo1"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:max="180"
                            android:progress="90"
                            android:progressTint="@color/amber"
                            android:thumbTint="@color/amber" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:text="俯仰"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />

                        <SeekBar
                            android:id="@+id/seekServo2"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:max="180"
                            android:progress="90"
                            android:progressTint="@color/amber"
                            android:thumbTint="@color/amber" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvServo1"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="2dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_chip_default"
                                android:gravity="center"
                                android:padding="4dp"
                                android:text="90°"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp" />

                            <TextView
                                android:id="@+id/tvServo2"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="2dp"
                                android:layout_weight="1"
                                android:background="@drawable/bg_chip_default"
                                android:gravity="center"
                                android:padding="4dp"
                                android:text="90°"
                                android:textColor="@color/text_primary"
                                android:textSize="10sp" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnServoCenter"
                            android:layout_width="match_parent"
                            android:layout_height="34dp"
                            android:layout_marginTop="8dp"
                            android:background="@drawable/bg_chip_default"
                            android:minWidth="0dp"
                            android:text="回正"
                            android:textAllCaps="false"
                            android:textColor="@color/text_secondary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_btn_danger"
                    android:text="紧急停止"
                    android:textAllCaps="false"
                    android:textColor="@color/red"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnAudioToggle"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_chip_selected_dark"
                    android:minWidth="0dp"
                    android:text="播放儿歌"
                    android:textAllCaps="false"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageMonitor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/SectionLabel"
                        android:text="环境概览" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvTemp"
                                style="@style/MonitorValue"
                                android:text="--" />

                            <TextView
                                style="@style/MonitorLabel"
                                android:text="温度 °C" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvDistance"
                                style="@style/MonitorValue"
                                android:text="--" />

                            <TextView
                                style="@style/MonitorLabel"
                                android:text="距离" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginRight="8dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvLightLux"
                                style="@style/MonitorValue"
                                android:text="--" />

                            <TextView
                                style="@style/MonitorLabel"
                                android:text="光照 lux" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvSmoke"
                                style="@style/MonitorValue"
                                android:text="--" />

                            <TextView
                                style="@style/MonitorLabel"
                                android:text="烟雾" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        style="@style/SectionLabel"
                        android:text="安全状态" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvCry"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="正常"
                            android:textColor="@color/green"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCryScore"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvVolume"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="音量 --"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvFps"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="帧率 --"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="环境趋势 · 近5分钟"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />

                    <com.example.raspbotapp.ui.SimpleTrendView
                        android:id="@+id/trendView"
                        android:layout_width="match_parent"
                        android:layout_height="96dp"
                        android:layout_marginTop="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="距离   温度   光照"
                        android:textColor="@color/text_tertiary"
                        android:textSize="9sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageMessage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvAlertSummary"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="22sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="报警记录"
                            android:textColor="@color/text_tertiary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnClearAlertHistory"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_chip_default"
                        android:minWidth="0dp"
                        android:paddingLeft="12dp"
                        android:paddingRight="12dp"
                        android:text="全部清除"
                        android:textAllCaps="false"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAlertHistory"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_panel"
                    android:lineSpacingExtra="6dp"
                    android:minHeight="160dp"
                    android:padding="14dp"
                    android:text="-"
                    android:textColor="@color/text_primary"
                    android:textSize="12sp" />
            </LinearLayout>
        </ScrollView>

        <ScrollView
            android:id="@+id/pageMine"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:scrollbars="none"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_panel"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="连接方式"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/etHost"
                        android:layout_width="150dp"
                        android:layout_height="36dp"
                        android:background="@drawable/bg_input"
                        android:inputType="text"
                        android:paddingLeft="8dp"
                        android:paddingRight="8dp"
                        android:singleLine="true"
                        android:hint="云端"
                        android:text="云端"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_tertiary"
                        android:textSize="11sp" />

                    <Button
                        android:id="@+id/btnApplyHost"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginLeft="6dp"
                        android:background="@drawable/bg_chip_selected"
                        android:minWidth="0dp"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:text="应用"
                        android:textAllCaps="false"
                        android:textColor="@color/bg_deepest"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical">

                    <LinearLayout
                        style="@style/SettingRow">

                        <TextView
                            style="@style/SettingText"
                            android:text="发送提示" />

                        <Switch
                            android:id="@+id/swVoicePrompt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingRow">

                        <TextView
                            style="@style/SettingText"
                            android:text="自动追踪" />

                        <Switch
                            android:id="@+id/swTrackingMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_panel"
                    android:orientation="vertical">

                    <LinearLayout
                        style="@style/SettingRow">

                        <TextView
                            style="@style/SettingText"
                            android:text="版本" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.0.0"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <LinearLayout
                        style="@style/SettingRow">

                        <TextView
                            style="@style/SettingText"
                            android:text="开源许可" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MIT"
                            android:textColor="@color/text_tertiary"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:background="@color/bg_surface"
        android:orientation="horizontal"
        android:paddingTop="3dp"
        android:paddingBottom="7dp">

        <Button
            android:id="@+id/btnTabHome"
            style="@style/BottomNavButton"
            android:text="首页" />

        <Button
            android:id="@+id/btnTabControl"
            style="@style/BottomNavButton"
            android:text="控制" />

        <Button
            android:id="@+id/btnTabMonitor"
            style="@style/BottomNavButton"
            android:text="监控" />

        <Button
            android:id="@+id/btnTabMessage"
            style="@style/BottomNavButton"
            android:text="消息" />

        <Button
            android:id="@+id/btnTabMine"
            style="@style/BottomNavButton"
            android:text="设置" />
    </LinearLayout>
</LinearLayout>
